{
  "appId": "com.skkut.ai-images-browser",
  "productName": "SilkStack Image Browser",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "src/services/fileWatcher.mjs",
    "public/icon.ico",
    "public/logo1.png"
  ],
  "win": {
    "icon": "public/icon.ico",
    "target": [
      "nsis",
      "zip"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "cscLink": null,
    "cscKeyPassword": null
  },
  "mac": {
    "icon": "public/logo1.png",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "category": "public.app-category.productivity",
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "identity": null
  },
  "linux": {
    "icon": "public/logo1.png",
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "category": "Utility",
    "synopsis": "Local image browser for AI generated images",
    "generateUpdatesFilesForAllChannels": true
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "artifactName": "AIImagesBrowser-Setup-${version}.${ext}"
  },
  "publish": {
    "provider": "github",
    "owner": "skkut",
    "repo": "ai-images-browser",
    "releaseType": "release"
  },
  "generateUpdatesFilesForAllChannels": true
}
